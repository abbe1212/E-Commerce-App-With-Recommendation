@{
    ViewData["Title"] = "Payment Cancelled";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow text-center">
                <div class="card-body py-5">
                    <i class="bi bi-x-circle text-warning" style="font-size: 4rem;"></i>
                    <h2 class="mt-3">Payment Cancelled</h2>
                    <p class="text-muted">Your payment was not processed.</p>
                    <p>Order #@ViewBag.OrderId</p>
                    <div class="mt-4">
                        <a asp-action="Index" asp-route-orderId="@ViewBag.OrderId" class="btn btn-primary">Try Again</a>
                        <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-secondary">Back to Cart</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
