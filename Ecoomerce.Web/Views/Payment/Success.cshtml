@{
    ViewData["Title"] = "Payment Successful";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow text-center">
                <div class="card-body py-5">
                    <i class="bi bi-check-circle text-success" style="font-size: 4rem;"></i>
                    <h2 class="mt-3">Payment Successful!</h2>
                    <p class="text-muted">Thank you for your order.</p>
                    <p>Order #@ViewBag.OrderId</p>
                    @if (!string.IsNullOrEmpty(ViewBag.SessionId as string)) {
                        <p class="small text-muted">Session: @ViewBag.SessionId</p>
                    }
                    <div class="mt-4">
                        <a asp-area="Profile" asp-controller="OrderHistory" asp-action="Details" asp-route-orderId="@ViewBag.OrderId" class="btn btn-primary">View Order Details</a>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Continue Shopping</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
