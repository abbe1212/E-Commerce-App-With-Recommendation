@model IEnumerable<Ecommerce.Application.DTOs.Reporting.InventoryReportDto>
@{
    ViewData["Title"] = "Low Stock Products";
}

<partial name="_ReportingNavigation" />

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div>
                    <h1 class="h4 mb-0">Low Stock Products</h1>
                    <p class="text-muted mb-0">Products below reorder threshold requiring attention</p>
                </div>
            </div>
            
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            
            <div class="card shadow-sm mb-3">
                <div class="card-body">
                    <form method="get" class="d-flex gap-2">
                        <input type="number" name="threshold" class="form-control" style="width: auto;"
                               value="@ViewBag.Threshold" placeholder="Stock Threshold" min="1">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-funnel"></i> Apply
                        </button>
                    </form>
                </div>
            </div>
            
            <div class="card shadow-sm">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Product Name</th>
                                    <th>Current Stock</th>
                                    <th>Category</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@item.ProductName</td>
                                        <td>
                                            <span class="badge @(item.CurrentStock < 5 ? "bg-danger" : "bg-warning")">
                                                @item.CurrentStock
                                            </span>
                                        </td>
                                        <td>@item.CategoryName</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        
                        @if (!Model.Any())
                        {
                            <div class="text-center py-5">
                                <i class="bi bi-check-circle fs-1 text-success"></i>
                                <p class="text-muted mt-2">No low stock products. Inventory levels are healthy!</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
