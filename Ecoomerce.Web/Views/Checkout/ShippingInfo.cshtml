@model Ecommerce.Application.ViewModels.CheckoutViewModel
@{
    ViewData["Title"] = "Shipping Information";
}

<div class="container py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="h3">Checkout</h1>
        </div>
    </div>

    <!-- Checkout Progress -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="checkout-progress">
                <div class="progress" style="height: 4px;">
                    <div class="progress-bar bg-primary" role="progressbar" style="width: 50%;" aria-valuenow="50" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
                <div class="d-flex justify-content-between mt-2">
                    <div class="step completed">
                        <div class="step-icon">
                            <i class="bi bi-check"></i>
                        </div>
                        <div class="step-label">Cart Summary</div>
                    </div>
                    <div class="step active">
                        <div class="step-icon">
                            <i class="bi bi-geo-alt"></i>
                        </div>
                        <div class="step-label">Shipping</div>
                    </div>
                    <div class="step">
                        <div class="step-icon">
                            <i class="bi bi-credit-card"></i>
                        </div>
                        <div class="step-label">Payment</div>
                    </div>
                    <div class="step">
                        <div class="step-icon">
                            <i class="bi bi-check-circle"></i>
                        </div>
                        <div class="step-label">Confirmation</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <form asp-action="PaymentMethod" method="post" class="needs-validation" novalidate>
        <div class="row g-4">
            <!-- Shipping Information -->
            <div class="col-lg-8">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white">
                        <h5 class="mb-0">Shipping Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label for="fullName" class="form-label">Full Name</label>
                            <input asp-for="FullName" type="text" class="form-control" id="fullName" required>
                            <div class="invalid-feedback">
                                Please enter your full name.
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label for="email" class="form-label">Email Address</label>
                            <input asp-for="Email" type="email" class="form-control" id="email" required>
                            <div class="invalid-feedback">
                                Please enter a valid email address.
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label for="phone" class="form-label">Phone Number</label>
                            <input asp-for="Phone" type="tel" class="form-control" id="phone" required>
                            <div class="invalid-feedback">
                                Please enter your phone number.
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label for="shippingAddress" class="form-label">Shipping Address</label>
                            <textarea asp-for="ShippingAddress" class="form-control" id="shippingAddress" rows="3" required></textarea>
                            <div class="invalid-feedback">
                                Please enter your shipping address.
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label for="city" class="form-label">City</label>
                            <input asp-for="City" type="text" class="form-control" id="city" required>
                            <div class="invalid-feedback">
                                Please enter your city.
                            </div>
                        </div>
                        
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="state" class="form-label">State/Province</label>
                                <input asp-for="State" type="text" class="form-control" id="state" required>
                                <div class="invalid-feedback">
                                    Please enter your state or province.
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label for="zipCode" class="form-label">Zip/Postal Code</label>
                                <input asp-for="ZipCode" type="text" class="form-control" id="zipCode" required>
                                <div class="invalid-feedback">
                                    Please enter your zip or postal code.
                                </div>
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label for="country" class="form-label">Country</label>
                            <select asp-for="Country" class="form-select" id="country" required>
                                <option value="">Select Country</option>
                                <option value="US">United States</option>
                                <option value="CA">Canada</option>
                                <option value="UK">United Kingdom</option>
                                <option value="AU">Australia</option>
                                <option value="EG">Egypt</option>
                                <!-- Add more countries as needed -->
                            </select>
                            <div class="invalid-feedback">
                                Please select your country.
                            </div>
                        </div>
                        
                        <div class="form-check mb-3">
                            <input asp-for="UseShippingAsBilling" class="form-check-input" type="checkbox" id="useShippingAsBilling" checked>
                            <label class="form-check-label" for="useShippingAsBilling">
                                Use shipping address as billing address
                            </label>
                        </div>
                        
                        <div id="billingAddressSection" class="d-none">
                            <hr>
                            <h5 class="mb-3">Billing Address</h5>
                            
                            <div class="mb-3">
                                <label for="billingAddress" class="form-label">Billing Address</label>
                                <textarea asp-for="BillingAddress" class="form-control" id="billingAddress" rows="3"></textarea>
                            </div>
                            
                            <div class="mb-3">
                                <label for="billingCity" class="form-label">City</label>
                                <input type="text" class="form-control" id="billingCity">
                            </div>
                            
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label for="billingState" class="form-label">State/Province</label>
                                    <input type="text" class="form-control" id="billingState">
                                </div>
                                <div class="col-md-6">
                                    <label for="billingZipCode" class="form-label">Zip/Postal Code</label>
                                    <input type="text" class="form-control" id="billingZipCode">
                                </div>
                            </div>
                            
                            <div class="mb-3">
                                <label for="billingCountry" class="form-label">Country</label>
                                <select class="form-select" id="billingCountry">
                                    <option value="">Select Country</option>
                                    <option value="US">United States</option>
                                    <option value="CA">Canada</option>
                                    <option value="UK">United Kingdom</option>
                                    <option value="AU">Australia</option>
                                    <option value="EG">Egypt</option>
                                    <!-- Add more countries as needed -->
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Shipping Method Selection -->
                <div class="card shadow-sm border-0 mt-4">
                    <div class="card-header bg-white">
                        <h5 class="mb-0"><i class="bi bi-truck me-2"></i>Shipping Method</h5>
                    </div>
                    <div class="card-body">
                        <div class="shipping-methods" id="shippingMethodsContainer">
                            <!-- Standard Shipping -->
                            <div class="form-check shipping-option mb-3 p-3 border rounded">
                                <input class="form-check-input" type="radio" name="ShippingMethod" 
                                       id="standardShipping" value="standard" checked data-cost="50" data-days="5">
                                <label class="form-check-label w-100" for="standardShipping">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <strong>Standard Shipping</strong>
                                            <div class="text-muted small">
                                                <i class="bi bi-calendar-check me-1"></i>
                                                Estimated delivery: <span class="estimated-date" id="standardDate"></span>
                                            </div>
                                        </div>
                                        <span class="badge bg-secondary fs-6">$50.00</span>
                                    </div>
                                </label>
                            </div>

                            <!-- Express Shipping -->
                            <div class="form-check shipping-option mb-3 p-3 border rounded">
                                <input class="form-check-input" type="radio" name="ShippingMethod" 
                                       id="expressShipping" value="express" data-cost="150" data-days="2">
                                <label class="form-check-label w-100" for="expressShipping">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <strong>Express Shipping</strong>
                                            <span class="badge bg-primary ms-2">Fastest</span>
                                            <div class="text-muted small">
                                                <i class="bi bi-lightning me-1"></i>
                                                Estimated delivery: <span class="estimated-date" id="expressDate"></span>
                                            </div>
                                        </div>
                                        <span class="badge bg-primary fs-6">$150.00</span>
                                    </div>
                                </label>
                            </div>

                            <!-- Free Shipping (if applicable) -->
                            <div class="form-check shipping-option p-3 border rounded border-success d-none" id="freeShippingOption">
                                <input class="form-check-input" type="radio" name="ShippingMethod" 
                                       id="freeShipping" value="free" data-cost="0" data-days="7">
                                <label class="form-check-label w-100" for="freeShipping">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <strong class="text-success">Free Shipping</strong>
                                            <span class="badge bg-success ms-2">Best Value</span>
                                            <div class="text-muted small">
                                                <i class="bi bi-gift me-1"></i>
                                                Estimated delivery: <span class="estimated-date" id="freeDate"></span>
                                            </div>
                                        </div>
                                        <span class="badge bg-success fs-6">FREE</span>
                                    </div>
                                </label>
                            </div>
                        </div>

                        <div class="alert alert-info mt-3 mb-0" id="deliveryEstimate">
                            <i class="bi bi-info-circle me-2"></i>
                            <span id="deliveryMessage">Your order will arrive by <strong id="selectedDeliveryDate"></strong></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Order Summary -->
            <div class="col-lg-4">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white">
                        <h5 class="mb-0">Order Summary</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Subtotal</span>
                            <span>@Model.Cart.SubTotal.ToString("C")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Shipping</span>
                            <span>@Model.Cart.Shipping.ToString("C")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Tax</span>
                            <span>@Model.Cart.Tax.ToString("C")</span>
                        </div>
                        @if (Model.Cart.Discount > 0)
                        {
                            <div class="d-flex justify-content-between mb-2 text-success">
                                <span>Discount</span>
                                <span>-@Model.Cart.Discount.ToString("C")</span>
                            </div>
                        }
                        <hr>
                        <div class="d-flex justify-content-between mb-3">
                            <strong>Total</strong>
                            <strong>@Model.Cart.Total.ToString("C")</strong>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">Continue to Payment</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Back to Cart Summary</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        // Form validation
        (function () {
            'use strict'
            
            // Fetch all forms we want to apply validation to
            var forms = document.querySelectorAll('.needs-validation')
            
            // Loop over them and prevent submission
            Array.prototype.slice.call(forms)
                .forEach(function (form) {
                    form.addEventListener('submit', function (event) {
                        if (!form.checkValidity()) {
                            event.preventDefault()
                            event.stopPropagation()
                        }
                        
                        form.classList.add('was-validated')
                    }, false)
                })
        })()
        
        // Toggle billing address section
        document.getElementById('useShippingAsBilling').addEventListener('change', function() {
            const billingSection = document.getElementById('billingAddressSection');
            if (this.checked) {
                billingSection.classList.add('d-none');
            } else {
                billingSection.classList.remove('d-none');
            }
        });

        // Shipping method selection
        function formatDate(date) {
            const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
            return date.toLocaleDateString('en-US', options);
        }

        function updateEstimatedDates() {
            const today = new Date();
            
            // Standard shipping (5 business days)
            const standardDate = new Date(today);
            standardDate.setDate(standardDate.getDate() + 5);
            document.getElementById('standardDate').textContent = formatDate(standardDate);
            
            // Express shipping (2 business days)
            const expressDate = new Date(today);
            expressDate.setDate(expressDate.getDate() + 2);
            document.getElementById('expressDate').textContent = formatDate(expressDate);
            
            // Free shipping (7 business days)
            const freeDate = new Date(today);
            freeDate.setDate(freeDate.getDate() + 7);
            const freeDateElement = document.getElementById('freeDate');
            if (freeDateElement) {
                freeDateElement.textContent = formatDate(freeDate);
            }
        }

        function updateSelectedDeliveryDate() {
            const selectedMethod = document.querySelector('input[name="ShippingMethod"]:checked');
            if (selectedMethod) {
                const days = parseInt(selectedMethod.dataset.days);
                const deliveryDate = new Date();
                deliveryDate.setDate(deliveryDate.getDate() + days);
                document.getElementById('selectedDeliveryDate').textContent = formatDate(deliveryDate);
                
                // Update shipping cost in summary
                const cost = parseFloat(selectedMethod.dataset.cost);
                const shippingElement = document.getElementById('shippingCost');
                if (shippingElement) {
                    shippingElement.textContent = cost === 0 ? 'FREE' : `$${cost.toFixed(2)}`;
                }
                
                // Update total
                updateOrderTotal(cost);
            }
        }

        function updateOrderTotal(shippingCost) {
            const subtotal = parseFloat(document.getElementById('subtotalValue')?.dataset.value || 0);
            const tax = parseFloat(document.getElementById('taxValue')?.dataset.value || 0);
            const discount = parseFloat(document.getElementById('discountValue')?.dataset.value || 0);
            const total = subtotal + tax + shippingCost - discount;
            
            const totalElement = document.getElementById('orderTotal');
            if (totalElement) {
                totalElement.textContent = `$${total.toFixed(2)}`;
            }
        }

        // Initialize dates on page load
        updateEstimatedDates();
        updateSelectedDeliveryDate();

        // Listen for shipping method changes
        document.querySelectorAll('input[name="ShippingMethod"]').forEach(function(radio) {
            radio.addEventListener('change', function() {
                updateSelectedDeliveryDate();
                
                // Add selected style
                document.querySelectorAll('.shipping-option').forEach(opt => {
                    opt.classList.remove('border-primary', 'bg-light');
                });
                this.closest('.shipping-option').classList.add('border-primary', 'bg-light');
            });
        });

        // Initialize selected style
        const initialSelected = document.querySelector('input[name="ShippingMethod"]:checked');
        if (initialSelected) {
            initialSelected.closest('.shipping-option').classList.add('border-primary', 'bg-light');
        }
    </script>
}

@section Styles {
    <style>
        .checkout-progress .step {
            text-align: center;
            width: 25%;
            position: relative;
        }
        
        .checkout-progress .step-icon {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background-color: #f8f9fa;
            border: 2px solid #dee2e6;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto;
            font-size: 1.2rem;
            color: #6c757d;
        }
        
        .checkout-progress .step.active .step-icon {
            background-color: #0d6efd;
            border-color: #0d6efd;
            color: white;
        }
        
        .checkout-progress .step.completed .step-icon {
            background-color: #198754;
            border-color: #198754;
            color: white;
        }
        
        .checkout-progress .step-label {
            margin-top: 0.5rem;
            font-size: 0.875rem;
            color: #6c757d;
        }
        
        .checkout-progress .step.active .step-label {
            color: #0d6efd;
            font-weight: 600;
        }
        
        .checkout-progress .step.completed .step-label {
            color: #198754;
            font-weight: 600;
        }

        .shipping-option {
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .shipping-option:hover {
            border-color: #0d6efd !important;
            background-color: #f8f9fa;
        }

        .shipping-option.border-primary {
            border-width: 2px !important;
        }

        .shipping-option .form-check-input {
            margin-top: 0.5rem;
        }
    </style>
}