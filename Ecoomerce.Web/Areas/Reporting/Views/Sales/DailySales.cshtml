@model IEnumerable<Ecommerce.Application.DTOs.Reporting.DailySalesDto>
@{
    ViewData["Title"] = "Daily Sales Report";
}

<partial name="_ReportingNavigation" />

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div>
                    <h1 class="h4 mb-0">Daily Sales Report</h1>
                    <p class="text-muted mb-0">View daily sales breakdown with order count and revenue metrics</p>
                </div>
            </div>
            
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            
            <div class="card shadow-sm mb-3">
                <div class="card-body">
                    <form method="get" class="d-flex gap-2">
                        <input type="date" name="startDate" class="form-control" 
                               value="@ViewBag.StartDate" placeholder="Start Date">
                        <input type="date" name="endDate" class="form-control" 
                               value="@ViewBag.EndDate" placeholder="End Date">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-funnel"></i> Filter
                        </button>
                    </form>
                </div>
            </div>
            
            <div class="card shadow-sm">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Orders Count</th>
                                    <th>Revenue</th>
                                    <th>Avg Order Value</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@item.Date.ToString("MM/dd/yyyy")</td>
                                        <td>@item.OrderCount</td>
                                        <td>@item.Revenue.ToString("C")</td>
                                        <td>@(item.OrderCount > 0 ? (item.Revenue / item.OrderCount).ToString("C") : "$0.00")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        
                        @if (!Model.Any())
                        {
                            <div class="text-center py-5">
                                <i class="bi bi-inbox fs-1 text-muted"></i>
                                <p class="text-muted mt-2">No daily sales data available for the selected period.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
