@using Ecommerce.Core.Enums
@{
    ViewData["Title"] = "Order Management";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var orders = ViewBag.Orders as List<Ecommerce.Application.DTOs.Order.OrderDto> ?? new List<Ecommerce.Application.DTOs.Order.OrderDto>();
    var statusFilter = ViewBag.StatusFilter as string ?? "";
    var searchTerm = ViewBag.SearchTerm as string ?? "";
    var currentPage = ViewBag.CurrentPage ?? 1;
    var totalPages = ViewBag.TotalPages ?? 1;
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="h4 mb-0">@ViewData["Title"]</h1>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Filter Form -->
<div class="card shadow-sm mb-3">
    <div class="card-body">
        <form method="get" asp-action="Index">
            <div class="row g-3">
                <div class="col-md-4">
                    <label for="statusFilter" class="form-label">Status</label>
                    <select name="statusFilter" id="statusFilter" class="form-select">
                        <option value="">All Statuses</option>
                        <option value="pending" selected="@(statusFilter == "pending")">Pending</option>
                        <option value="processing" selected="@(statusFilter == "processing")">Processing</option>
                        <option value="confirmed" selected="@(statusFilter == "confirmed")">Confirmed</option>
                        <option value="shipped" selected="@(statusFilter == "shipped")">Shipped</option>
                        <option value="delivered" selected="@(statusFilter == "delivered")">Delivered</option>
                        <option value="cancelled" selected="@(statusFilter == "cancelled")">Cancelled</option>
                        <option value="returned" selected="@(statusFilter == "returned")">Returned</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label for="searchTerm" class="form-label">Search</label>
                    <input type="text" name="searchTerm" id="searchTerm" class="form-control" 
                           placeholder="Search by Order ID or User ID" value="@searchTerm" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-filter"></i> Filter
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Bulk Actions Form -->
<form method="post" asp-action="BulkUpdateStatus" id="bulkForm">
    @Html.AntiForgeryToken()
    
    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <div class="d-flex align-items-center gap-2">
                <label class="mb-0">Bulk Action:</label>
                <select name="newStatus" class="form-select w-auto">
                    <option value="@OrderStatus.pending">Set to Pending</option>
                    <option value="@OrderStatus.processing">Set to Processing</option>
                    <option value="@OrderStatus.confirmed">Set to Confirmed</option>
                    <option value="@OrderStatus.shipped">Set to Shipped</option>
                    <option value="@OrderStatus.delivered">Set to Delivered</option>
                    <option value="@OrderStatus.cancelled">Set to Cancelled</option>
                    <option value="@OrderStatus.returned">Set to Returned</option>
                </select>
                <button type="submit" class="btn btn-warning">
                    <i class="bi bi-lightning-fill"></i> Apply to Selected
                </button>
            </div>
        </div>
    </div>

    <!-- Orders Table -->
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 40px;">
                                <input type="checkbox" id="selectAll" class="form-check-input" />
                            </th>
                            <th>Order #</th>
                            <th>User ID</th>
                            <th>Date</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th style="width: 300px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (orders.Any())
                        {
                            @foreach (var order in orders)
                            {
                                <tr>
                                    <td>
                                        <input type="checkbox" name="orderIds" value="@order.OrderID" class="form-check-input order-checkbox" />
                                    </td>
                                    <td><strong>#@order.OrderID</strong></td>
                                    <td>@order.UserID</td>
                                    <td>@order.OrderDate.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td><strong>@order.TotalAmount.ToString("C")</strong></td>
                                    <td>
                                        <span class="badge bg-@GetStatusBadgeClass(order.Status)">
                                            @order.Status.ToString()
                                        </span>
                                    </td>
                                    <td>
                                        <div class="d-flex gap-2 align-items-center">
                                            <form method="post" asp-action="UpdateStatus" class="d-inline-flex gap-1 align-items-center">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="orderId" value="@order.OrderID" />
                                                <select name="newStatus" class="form-select form-select-sm" style="width: 140px;">
                                                    <option value="@OrderStatus.pending" selected="@(order.Status == OrderStatus.pending)">Pending</option>
                                                    <option value="@OrderStatus.processing" selected="@(order.Status == OrderStatus.processing)">Processing</option>
                                                    <option value="@OrderStatus.confirmed" selected="@(order.Status == OrderStatus.confirmed)">Confirmed</option>
                                                    <option value="@OrderStatus.shipped" selected="@(order.Status == OrderStatus.shipped)">Shipped</option>
                                                    <option value="@OrderStatus.delivered" selected="@(order.Status == OrderStatus.delivered)">Delivered</option>
                                                    <option value="@OrderStatus.cancelled" selected="@(order.Status == OrderStatus.cancelled)">Cancelled</option>
                                                    <option value="@OrderStatus.returned" selected="@(order.Status == OrderStatus.returned)">Returned</option>
                                                </select>
                                                <button type="submit" class="btn btn-sm btn-primary">Update</button>
                                            </form>
                                            <a asp-action="Details" asp-route-orderId="@order.OrderID" class="btn btn-sm btn-outline-secondary">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">No orders to display.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</form>

<!-- Pagination -->
@if (totalPages > 1)
{
    <nav aria-label="Orders pagination" class="mt-3">
        <ul class="pagination justify-content-center">
            @if (currentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="?page=@(currentPage - 1)&statusFilter=@statusFilter&searchTerm=@searchTerm">Previous</a>
                </li>
            }
            else
            {
                <li class="page-item disabled">
                    <span class="page-link">Previous</span>
                </li>
            }

            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" href="?page=@i&statusFilter=@statusFilter&searchTerm=@searchTerm">@i</a>
                </li>
            }

            @if (currentPage < totalPages)
            {
                <li class="page-item">
                    <a class="page-link" href="?page=@(currentPage + 1)&statusFilter=@statusFilter&searchTerm=@searchTerm">Next</a>
                </li>
            }
            else
            {
                <li class="page-item disabled">
                    <span class="page-link">Next</span>
                </li>
            }
        </ul>
    </nav>
}

@functions {
    string GetStatusBadgeClass(OrderStatus status)
    {
        return status switch
        {
            OrderStatus.pending => "secondary",
            OrderStatus.processing => "info",
            OrderStatus.confirmed => "primary",
            OrderStatus.shipped => "warning",
            OrderStatus.delivered => "success",
            OrderStatus.cancelled => "danger",
            OrderStatus.returned => "dark",
            _ => "secondary"
        };
    }
}

@section Scripts {
    <script>
        // Select All checkbox functionality
        document.getElementById('selectAll').addEventListener('change', function() {
            const checkboxes = document.querySelectorAll('.order-checkbox');
            checkboxes.forEach(cb => cb.checked = this.checked);
        });

        // Update Select All state when individual checkboxes change
        document.querySelectorAll('.order-checkbox').forEach(cb => {
            cb.addEventListener('change', function() {
                const selectAll = document.getElementById('selectAll');
                const allChecked = Array.from(document.querySelectorAll('.order-checkbox')).every(cb => cb.checked);
                selectAll.checked = allChecked;
            });
        });

        // Validate bulk form submission
        document.getElementById('bulkForm').addEventListener('submit', function(e) {
            const checkedBoxes = document.querySelectorAll('.order-checkbox:checked');
            if (checkedBoxes.length === 0) {
                e.preventDefault();
                alert('Please select at least one order.');
            }
        });
    </script>
}

