@{
    ViewData["Title"] = "Revenue Report";
}

<partial name="_ReportingNavigation" />

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div>
                    <h1 class="h4 mb-0">Revenue Report</h1>
                    <p class="text-muted mb-0">View total revenue for selected period</p>
                </div>
            </div>
            
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            
            <div class="card shadow-sm mb-3">
                <div class="card-body">
                    <form method="get" class="d-flex gap-2">
                        <input type="date" name="startDate" class="form-control" 
                               value="@ViewBag.StartDate" placeholder="Start Date">
                        <input type="date" name="endDate" class="form-control" 
                               value="@ViewBag.EndDate" placeholder="End Date">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-funnel"></i> Filter
                        </button>
                    </form>
                </div>
            </div>
            
            <div class="card shadow-sm">
                <div class="card-body text-center py-5">
                    <div class="mb-3">
                        <i class="bi bi-currency-dollar fs-1 text-success"></i>
                    </div>
                    <h2 class="display-4 fw-semibold text-success mb-2">@(((decimal?)ViewBag.TotalRevenue ?? 0m).ToString("C"))</h2>
                    <p class="text-muted">Total Revenue</p>
                    @if (ViewBag.StartDate != null && ViewBag.EndDate != null)
                    {
                        <p class="text-muted small">
                            Period: @ViewBag.StartDate to @ViewBag.EndDate
                        </p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
