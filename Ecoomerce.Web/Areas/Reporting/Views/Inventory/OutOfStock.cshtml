@model IEnumerable<Ecommerce.Application.DTOs.Reporting.InventoryReportDto>
@{
    ViewData["Title"] = "Out of Stock Products";
}

<partial name="_ReportingNavigation" />

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div>
                    <h1 class="h4 mb-0">Out of Stock Products</h1>
                    <p class="text-muted mb-0">Products currently unavailable and requiring immediate restocking</p>
                </div>
            </div>
            
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            
            <div class="card shadow-sm">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Product Name</th>
                                    <th>Product ID</th>
                                    <th>Category</th>
                                    <th>Last Updated</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@item.ProductName</td>
                                        <td>@item.ProductId</td>
                                        <td>@item.CategoryName</td>
                                        <td>@item.LastUpdated.ToString("MM/dd/yyyy HH:mm")</td>
                                        <td><span class="badge bg-danger">Out of Stock</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        
                        @if (!Model.Any())
                        {
                            <div class="text-center py-5">
                                <i class="bi bi-check-circle fs-1 text-success"></i>
                                <p class="text-muted mt-2">No out of stock products. All items are available!</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
