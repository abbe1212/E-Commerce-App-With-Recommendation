@model IEnumerable<Ecommerce.Application.DTOs.Reporting.UserActivityDto>
@{
    ViewData["Title"] = "User Activity Report";
}

<partial name="_ReportingNavigation" />

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div>
                    <h1 class="h4 mb-0">User Activity Report</h1>
                    <p class="text-muted mb-0">Track user actions and system interactions</p>
                </div>
            </div>
            
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            
            <div class="card shadow-sm">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>User Email</th>
                                    <th>Last Login</th>
                                    <th>Cart Items</th>
                                    <th>Wishlist Items</th>
                                    <th>Reviews</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@item.Email</td>
                                        <td>@item.LastLoginDate.ToString("MM/dd/yyyy HH:mm")</td>
                                        <td>@item.CartItemsCount</td>
                                        <td>@item.WishlistItemsCount</td>
                                        <td>@item.ReviewsCount</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        
                        @if (!Model.Any())
                        {
                            <div class="text-center py-5">
                                <i class="bi bi-inbox fs-1 text-muted"></i>
                                <p class="text-muted mt-2">No user activity data available.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
