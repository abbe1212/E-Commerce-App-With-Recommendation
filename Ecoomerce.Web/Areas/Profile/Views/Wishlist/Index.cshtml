@using Ecommerce.Application.ViewModels.User___Account
@model WishlistViewModel
@{
    ViewData["Title"] = "My Wishlist";
    Layout = "~/Areas/Profile/Views/Shared/_ProfileLayout.cshtml";
}

@Html.AntiForgeryToken()

<div class="container py-4">
    <!-- Page Header -->
    <div class="wishlist-header mb-5">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 mb-3">
                    <i class="bi bi-heart me-1"></i>My Collection
                </span>
                <h1 class="shop-title">My Wishlist</h1>
                <p class="shop-subtitle">Your saved items for later</p>
            </div>
            <div class="col-lg-6 text-lg-end">
                <div class="d-flex align-items-center justify-content-lg-end gap-3">
                    <span class="text-muted">
                        <strong>@Model.Items.Count</strong> items saved
                    </span>
                    @if (Model.Items.Any())
                    {
                        <button type="button" class="btn btn-primary" onclick="moveAllToCart()">
                            <i class="bi bi-bag-plus me-2"></i>Move All to Cart
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Wishlist Items -->
    @if (Model.Items.Any())
    {
        <div class="row g-4" id="wishlistGrid">
            @foreach (var item in Model.Items)
            {
                <div class="col-xl-3 col-lg-4 col-md-6" id="wishlist-item-@item.ProductID">
                    <div class="product-card-modern">
                        <!-- Image Container -->
                        <div class="product-image-wrapper">
                            <a asp-controller="Product" asp-action="Details" asp-area="" asp-route-id="@item.ProductID" class="product-image-link">
                                @if (!string.IsNullOrEmpty(item.ImageURL))
                                {
                                    <img src="@item.ImageURL" class="product-image-main" alt="@item.ProductName">
                                }
                                else
                                {
                                    <div class="product-image-placeholder">
                                        <i class="bi bi-image"></i>
                                    </div>
                                }
                            </a>
                            
                            <!-- Badges -->
                            <div class="product-badges">
                                @if (!item.IsAvailable)
                                {
                                    <span class="badge-out-of-stock">Out of Stock</span>
                                }
                            </div>
                            
                            <!-- Quick Actions Overlay -->
                            <div class="product-quick-actions">
                                @if (item.IsAvailable)
                                {
                                    <button type="button" class="quick-action-btn" onclick="moveToCart(@item.ProductID)" title="Move to Cart">
                                        <i class="bi bi-bag-plus"></i>
                                    </button>
                                }
                                <button type="button" class="quick-action-btn wishlist-btn active" onclick="removeFromWishlist(@item.ProductID)" title="Remove from Wishlist">
                                    <i class="bi bi-heart-fill"></i>
                                </button>
                                <a asp-controller="Product" asp-action="Details" asp-area="" asp-route-id="@item.ProductID" class="quick-action-btn" title="View Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </div>
                        </div>
                        
                        <!-- Product Info -->
                        <div class="product-info">
                            <!-- Added Date -->
                            <div class="product-category">
                                <i class="bi bi-clock me-1"></i>Added @item.AddedAt.ToString("MMM dd, yyyy")
                            </div>
                            
                            <!-- Title -->
                            <h5 class="product-title">
                                <a asp-controller="Product" asp-action="Details" asp-area="" asp-route-id="@item.ProductID">
                                    @item.ProductName
                                </a>
                            </h5>
                            
                            <!-- Price Row -->
                            <div class="product-price-row">
                                <span class="product-price">@item.Price.ToString("N0") <small>L.E</small></span>
                                @if (item.IsAvailable)
                                {
                                    <button type="button" class="add-to-cart-btn" onclick="moveToCart(@item.ProductID)" title="Move to Cart">
                                        <i class="bi bi-bag-plus"></i>
                                    </button>
                                }
                                else
                                {
                                    <span class="out-of-stock-label">Unavailable</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
        
        <!-- Continue Shopping Link -->
        <div class="text-center mt-5">
            <a asp-controller="Product" asp-action="Index" asp-area="" class="view-all-btn">
                <i class="bi bi-grid me-2"></i>Continue Shopping
                <i class="bi bi-arrow-right ms-2"></i>
            </a>
        </div>
    }
    else
    {
        <!-- Empty State -->
        <div class="empty-state-modern">
            <div class="empty-icon">
                <i class="bi bi-heart"></i>
            </div>
            <h4>Your Wishlist is Empty</h4>
            <p>Save items you love for later. Start exploring our products!</p>
            <a asp-controller="Product" asp-action="Index" asp-area="" class="view-all-btn mt-3">
                <i class="bi bi-shop me-2"></i>Start Shopping
                <i class="bi bi-arrow-right ms-2"></i>
            </a>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Move item to cart
        function moveToCart(productId) {
            $.ajax({
                url: '@Url.Action("MoveToCart", "Wishlist", new { area = "Profile" })',
                type: 'POST',
                data: { productId: productId },
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    if (response.success) {
                        // Remove item from grid with animation
                        const itemElement = document.getElementById('wishlist-item-' + productId);
                        if (itemElement) {
                            itemElement.style.transition = 'all 0.3s ease';
                            itemElement.style.opacity = '0';
                            itemElement.style.transform = 'scale(0.8)';
                            setTimeout(() => {
                                itemElement.remove();
                                updateItemCount();
                                checkEmptyState();
                            }, 300);
                        }
                        showNotification(response.message || 'Moved to cart!', 'success');
                        updateCartCount();
                    } else {
                        showNotification(response.message || 'Failed to move item', 'error');
                    }
                },
                error: function() {
                    showNotification('Failed to move item to cart', 'error');
                }
            });
        }

        // Remove from wishlist
        function removeFromWishlist(productId) {
            $.ajax({
                url: '@Url.Action("RemoveItem", "Wishlist", new { area = "Profile" })',
                type: 'POST',
                data: { productId: productId },
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    if (response.success) {
                        // Remove item from grid with animation
                        const itemElement = document.getElementById('wishlist-item-' + productId);
                        if (itemElement) {
                            itemElement.style.transition = 'all 0.3s ease';
                            itemElement.style.opacity = '0';
                            itemElement.style.transform = 'scale(0.8)';
                            setTimeout(() => {
                                itemElement.remove();
                                updateItemCount();
                                checkEmptyState();
                            }, 300);
                        }
                        showNotification('Removed from wishlist', 'info');
                    } else {
                        showNotification(response.message || 'Failed to remove item', 'error');
                    }
                },
                error: function() {
                    showNotification('Failed to remove item', 'error');
                }
            });
        }

        // Move all items to cart
        function moveAllToCart() {
            if (!confirm('Move all items to your cart?')) return;
            
            $.ajax({
                url: '@Url.Action("MoveAllToCart", "Wishlist", new { area = "Profile" })',
                type: 'POST',
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    if (response.success) {
                        showNotification(response.message || 'All items moved to cart!', 'success');
                        updateCartCount();
                        // Reload page to show empty state
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        showNotification(response.message || 'Failed to move items', 'error');
                    }
                },
                error: function() {
                    showNotification('Failed to move items to cart', 'error');
                }
            });
        }

        // Update item count in header
        function updateItemCount() {
            const itemCount = document.querySelectorAll('#wishlistGrid > div').length;
            const countElement = document.querySelector('.wishlist-header strong');
            if (countElement) {
                countElement.textContent = itemCount;
            }
        }

        // Check if wishlist is empty and show empty state
        function checkEmptyState() {
            const items = document.querySelectorAll('#wishlistGrid > div');
            if (items.length === 0) {
                location.reload();
            }
        }

        // Update cart count in navbar
        function updateCartCount() {
            $.ajax({
                url: '@Url.Action("GetCartCount", "Cart", new { area = "" })',
                type: 'GET',
                success: function(count) {
                    const badge = document.getElementById('cartCount');
                    if (badge) {
                        badge.textContent = count;
                        if (count > 0) {
                            badge.classList.remove('d-none');
                        }
                    }
                }
            });
        }

        // Show notification
        function showNotification(message, type) {
            var alertClass = type === 'success' ? 'alert-success' : 
                           type === 'error' ? 'alert-danger' : 
                           type === 'warning' ? 'alert-warning' : 'alert-info';
            
            var notification = $(`
                <div class="alert ${alertClass} alert-dismissible fade show position-fixed" 
                     style="top: 20px; right: 20px; z-index: 9999; min-width: 300px; border-radius: 12px; box-shadow: 0 8px 24px rgba(0,0,0,0.15);">
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `);
            
            $('body').append(notification);
            
            setTimeout(function() {
                notification.alert('close');
            }, 3000);
        }
    </script>
}

@section Styles {
    <style>
        /* Page Header */
        .wishlist-header {
            padding: 20px 0;
        }
        
        .shop-title {
            font-size: 2.5rem;
            font-weight: 700;
            color: var(--text-color);
            margin-bottom: 8px;
        }
        
        .shop-subtitle {
            font-size: 1.1rem;
            color: var(--text-muted);
            margin: 0;
        }
        
        .out-of-stock-label {
            font-size: 0.75rem;
            color: var(--danger-color);
            font-weight: 500;
        }
        
        /* Responsive */
        @@media (max-width: 767.98px) {
            .shop-title {
                font-size: 1.75rem;
            }
            
            .wishlist-header .d-flex {
                flex-direction: column;
                align-items: flex-start !important;
                gap: 1rem !important;
            }
        }
    </style>
}