@model IEnumerable<Ecommerce.Application.DTOs.Order.OrderDto>
@{
    ViewData["Title"] = "My Orders";
    var currentStatus = ViewBag.CurrentStatus as string;
    var currentSort = ViewBag.CurrentSort as string;
}

@Html.AntiForgeryToken()

<div class="container py-4">
    <!-- Page Header -->
    <div class="order-page-header mb-4">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h1 class="page-title">My Orders</h1>
                <p class="page-subtitle">Track and manage your order history</p>
            </div>
            <div class="col-lg-6 text-lg-end">
                <a asp-controller="Product" asp-action="Index" class="btn btn-outline-primary">
                    <i class="bi bi-bag me-2"></i>Continue Shopping
                </a>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="order-filters mb-4">
        <div class="row g-3 align-items-center">
            <div class="col-md-4">
                <label class="filter-label">Filter by Status</label>
                <select class="form-select" id="statusFilter" onchange="applyFilters()">
                    <option value="">All Orders</option>
                    <option value="pending" selected="@(currentStatus == "pending")">Pending</option>
                    <option value="processing" selected="@(currentStatus == "processing")">Processing</option>
                    <option value="shipped" selected="@(currentStatus == "shipped")">Shipped</option>
                    <option value="delivered" selected="@(currentStatus == "delivered")">Delivered</option>
                    <option value="cancelled" selected="@(currentStatus == "cancelled")">Cancelled</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="filter-label">Sort By</label>
                <select class="form-select" id="sortFilter" onchange="applyFilters()">
                    <option value="">Newest First</option>
                    <option value="date_asc" selected="@(currentSort == "date_asc")">Oldest First</option>
                    <option value="total_desc" selected="@(currentSort == "total_desc")">Highest Total</option>
                    <option value="total_asc" selected="@(currentSort == "total_asc")">Lowest Total</option>
                </select>
            </div>
            <div class="col-md-4 text-md-end">
                <span class="order-count">
                    <strong>@Model.Count()</strong> orders found
                </span>
            </div>
        </div>
    </div>

    <!-- Orders List -->
    @if (Model != null && Model.Any())
    {
        <div class="orders-list">
            @foreach (var order in Model)
            {
                var statusBadgeClass = order.Status switch
                {
                    Ecommerce.Core.Enums.OrderStatus.pending => "badge-pending",
                    Ecommerce.Core.Enums.OrderStatus.processing => "badge-processing",
                    Ecommerce.Core.Enums.OrderStatus.shipped => "badge-shipped",
                    Ecommerce.Core.Enums.OrderStatus.delivered => "badge-delivered",
                    Ecommerce.Core.Enums.OrderStatus.cancelled => "badge-cancelled",
                    _ => "badge-secondary"
                };

                <div class="order-card">
                    <div class="order-card-header">
                        <div class="order-info">
                            <span class="order-number">Order #@order.OrderID</span>
                            <span class="order-date">
                                <i class="bi bi-calendar3 me-1"></i>
                                @order.OrderDate.ToString("MMM dd, yyyy • hh:mm tt")
                            </span>
                        </div>
                        <span class="order-status-badge @statusBadgeClass">
                            @order.Status.ToString().ToUpper()
                        </span>
                    </div>
                    
                    <div class="order-card-body">
                        <div class="row">
                            <div class="col-md-8">
                                <div class="order-summary">
                                    <div class="summary-item">
                                        <i class="bi bi-box-seam"></i>
                                        <span>@order.ItemsCount item(s)</span>
                                    </div>
                                    <div class="summary-item">
                                        <i class="bi bi-geo-alt"></i>
                                        <span class="text-truncate" style="max-width: 300px;">@order.ShippingAddress</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4 text-md-end">
                                <div class="order-total">
                                    <span class="total-label">Total</span>
                                    <span class="total-amount">@order.TotalAmount.ToString("N0") L.E</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="order-card-footer">
                        <div class="order-actions">
                            <a asp-action="Details" asp-route-id="@order.OrderID" class="btn-order-action btn-view">
                                <i class="bi bi-eye me-1"></i>View Details
                            </a>
                            <a asp-action="Track" asp-route-id="@order.OrderID" class="btn-order-action btn-track">
                                <i class="bi bi-truck me-1"></i>Track
                            </a>
                            @if (order.Status == Ecommerce.Core.Enums.OrderStatus.pending || order.Status == Ecommerce.Core.Enums.OrderStatus.processing)
                            {
                                <button type="button" class="btn-order-action btn-cancel" onclick="cancelOrder(@order.OrderID)">
                                    <i class="bi bi-x-circle me-1"></i>Cancel
                                </button>
                            }
                            @if (order.Status == Ecommerce.Core.Enums.OrderStatus.delivered)
                            {
                                <button type="button" class="btn-order-action btn-reorder" onclick="reorderItems(@order.OrderID)">
                                    <i class="bi bi-arrow-repeat me-1"></i>Reorder
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-orders">
            <div class="empty-icon">
                <i class="bi bi-bag-x"></i>
            </div>
            <h4>No Orders Yet</h4>
            <p>You haven't placed any orders yet. Start shopping to see your orders here!</p>
            <a asp-controller="Product" asp-action="Index" class="btn btn-primary">
                <i class="bi bi-bag me-2"></i>Start Shopping
            </a>
        </div>
    }
</div>

@section Scripts {
    <script>
        function applyFilters() {
            const status = document.getElementById('statusFilter').value;
            const sort = document.getElementById('sortFilter').value;
            
            let url = '@Url.Action("Index")';
            const params = [];
            
            if (status) params.push(`status=${status}`);
            if (sort) params.push(`sortBy=${sort}`);
            
            if (params.length > 0) {
                url += '?' + params.join('&');
            }
            
            window.location.href = url;
        }

        function cancelOrder(orderId) {
            if (!confirm('Are you sure you want to cancel this order? This action cannot be undone.')) {
                return;
            }
            
            $.ajax({
                url: '@Url.Action("Cancel")/' + orderId,
                type: 'POST',
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    if (response.success) {
                        showNotification(response.message, 'success');
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        showNotification(response.message, 'error');
                    }
                },
                error: function() {
                    showNotification('Failed to cancel order. Please try again.', 'error');
                }
            });
        }

        function reorderItems(orderId) {
            $.ajax({
                url: '@Url.Action("Reorder")/' + orderId,
                type: 'POST',
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    if (response.success) {
                        showNotification(response.message, 'success');
                        if (response.redirect) {
                            setTimeout(() => window.location.href = response.redirect, 1500);
                        }
                    } else {
                        showNotification(response.message, 'error');
                    }
                },
                error: function() {
                    showNotification('Failed to add items to cart. Please try again.', 'error');
                }
            });
        }

        function showNotification(message, type) {
            var alertClass = type === 'success' ? 'alert-success' : 
                           type === 'error' ? 'alert-danger' : 
                           type === 'warning' ? 'alert-warning' : 'alert-info';
            
            var notification = $(`
                <div class="alert ${alertClass} alert-dismissible fade show position-fixed" 
                     style="top: 20px; right: 20px; z-index: 9999; min-width: 300px; border-radius: 12px; box-shadow: 0 8px 24px rgba(0,0,0,0.15);">
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `);
            
            $('body').append(notification);
            
            setTimeout(function() {
                notification.alert('close');
            }, 4000);
        }
    </script>
}

@section Styles {
    <style>
        .order-page-header .page-title {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 8px;
        }
        
        .order-page-header .page-subtitle {
            color: var(--text-muted);
            margin-bottom: 0;
        }
        
        .order-filters {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 20px;
        }
        
        .filter-label {
            display: block;
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--text-muted);
            margin-bottom: 6px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .order-count {
            color: var(--text-secondary);
            font-size: 0.9rem;
        }
        
        .order-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            margin-bottom: 16px;
            overflow: hidden;
            transition: all 0.3s ease;
        }
        
        .order-card:hover {
            border-color: var(--primary-color);
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
        }
        
        .order-card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px 20px;
            background: var(--bg-secondary);
            border-bottom: 1px solid var(--border-color);
        }
        
        .order-number {
            font-weight: 700;
            font-size: 1.1rem;
            color: var(--text-color);
        }
        
        .order-date {
            font-size: 0.85rem;
            color: var(--text-muted);
            margin-left: 16px;
        }
        
        .order-status-badge {
            padding: 6px 14px;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .badge-pending { background: #fef3c7; color: #92400e; }
        .badge-processing { background: #dbeafe; color: #1e40af; }
        .badge-shipped { background: #e0e7ff; color: #3730a3; }
        .badge-delivered { background: #d1fae5; color: #065f46; }
        .badge-cancelled { background: #fee2e2; color: #991b1b; }
        
        .order-card-body {
            padding: 20px;
        }
        
        .order-summary {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        
        .summary-item {
            display: flex;
            align-items: center;
            gap: 10px;
            color: var(--text-secondary);
            font-size: 0.9rem;
        }
        
        .summary-item i {
            color: var(--text-muted);
        }
        
        .order-total {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
        }
        
        .total-label {
            font-size: 0.8rem;
            color: var(--text-muted);
            text-transform: uppercase;
        }
        
        .total-amount {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--text-color);
        }
        
        .order-card-footer {
            padding: 16px 20px;
            border-top: 1px solid var(--border-color);
            background: var(--bg-secondary);
        }
        
        .order-actions {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }
        
        .btn-order-action {
            padding: 8px 16px;
            border-radius: 8px;
            font-size: 0.85rem;
            font-weight: 500;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            transition: all 0.2s ease;
            border: none;
            cursor: pointer;
        }
        
        .btn-view {
            background: var(--primary-color);
            color: white;
        }
        
        .btn-view:hover {
            background: var(--primary-hover);
            color: white;
        }
        
        .btn-track {
            background: var(--bg-color);
            border: 1px solid var(--border-color);
            color: var(--text-color);
        }
        
        .btn-track:hover {
            border-color: var(--primary-color);
            color: var(--primary-color);
        }
        
        .btn-cancel {
            background: transparent;
            color: var(--danger-color);
        }
        
        .btn-cancel:hover {
            background: #fee2e2;
        }
        
        .btn-reorder {
            background: var(--success-color);
            color: white;
        }
        
        .btn-reorder:hover {
            background: #16a34a;
        }
        
        .empty-orders {
            text-align: center;
            padding: 60px 20px;
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 16px;
        }
        
        .empty-orders .empty-icon {
            width: 80px;
            height: 80px;
            background: var(--bg-secondary);
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 20px;
        }
        
        .empty-orders .empty-icon i {
            font-size: 2.5rem;
            color: var(--text-muted);
        }
        
        .empty-orders h4 {
            font-weight: 600;
            margin-bottom: 8px;
        }
        
        .empty-orders p {
            color: var(--text-muted);
            margin-bottom: 24px;
        }
        
        @@media (max-width: 768px) {
            .order-card-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 12px;
            }
            
            .order-date {
                margin-left: 0;
            }
            
            .order-total {
                align-items: flex-start;
                margin-top: 16px;
            }
            
            .order-actions {
                flex-direction: column;
            }
            
            .btn-order-action {
                justify-content: center;
            }
        }
    </style>
}
